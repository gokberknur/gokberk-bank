{
	"name": "gokberk-bank",
	"description": "gökberk bank — a personal banking + investing demo app, built with SvelteKit, dogfooding the @gokberknur/design-system component library.",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"author": "Gökberk Nur (https://gokberk.se)",
	"license": "MIT",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	}
}
